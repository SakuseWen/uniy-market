{
  "name": "uniy-market",
  "version": "1.0.0",
  "description": "University second-hand trading platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:prod": "NODE_ENV=production tsc && npm run copy-assets",
    "copy-assets": "cp -r public dist/ && cp -r src/locales dist/src/",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "seed:universities": "ts-node src/scripts/seedUniversityDomains.ts",
    "seed:test-data": "node scripts/setup-test-data.js",
    "setup": "npm install && npm run seed:test-data",
    "security:audit": "ts-node src/scripts/securityAudit.ts",
    "deploy": "cd deployment && ./deploy.sh",
    "docker:build": "docker build -f deployment/Dockerfile -t unity-market:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file deployment/.env unity-market:latest"
  },
  "keywords": [
    "university",
    "marketplace",
    "second-hand",
    "trading"
  ],
  "author": "Uniy Market Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/translate": "^9.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/sharp": "^0.32.0",
    "@types/socket.io-client": "^3.0.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
