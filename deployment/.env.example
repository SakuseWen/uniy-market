# Uniy Market 部署环境变量示例
# 复制此文件为 .env 并填写实际值

# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
DATABASE_URL=/app/data/unity_market.db

# JWT 配置（必须至少 32 个字符）
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-change-this-in-production
JWT_EXPIRES_IN=7d

# 会话配置（必须至少 32 个字符）
SESSION_SECRET=your-super-secret-session-key-at-least-32-characters-long-change-this-in-production

# Google OAuth 配置
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# 前端配置
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Google 服务配置
GOOGLE_TRANSLATE_API_KEY=your-production-google-translate-api-key
GOOGLE_MAPS_API_KEY=your-production-google-maps-api-key

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/app/public/uploads

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 安全配置
ENABLE_CSRF=true
ENABLE_HELMET=true
ENABLE_RATE_LIMIT=true

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
